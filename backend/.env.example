# ─── Base de Datos ────────────────────────────────────────
# En local usar SQLite (archivo local)
# En producción usar PostgreSQL (Neon / Render PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/financeflow?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET="cambia-este-secreto-por-uno-seguro"

# ─── Servidor ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend URL (para CORS en producción) ───────────────
CORS_ORIGIN="http://localhost:3000"
